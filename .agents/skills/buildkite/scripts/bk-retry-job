#!/usr/bin/env bash
# bk-retry-job: Retry a single Buildkite job without triggering a full build rebuild
#
# Usage: bk-retry-job <BUILD-NUMBER> <JOB-ID> [PIPELINE] [ORG]
#
# PIPELINE defaults to the current git repo name (e.g. "web" → "invoca/web").
# ORG defaults to "invoca".
# Buildkite API token is read from macOS Keychain (key: "buildkite-api-token").

set -euo pipefail

BUILD=${1:?Usage: bk-retry-job <BUILD-NUMBER> <JOB-ID> [PIPELINE] [ORG]}
JOB_ID=${2:?Usage: bk-retry-job <BUILD-NUMBER> <JOB-ID> [PIPELINE] [ORG]}

if [ -n "${3:-}" ]; then
  PIPELINE="$3"
else
  PIPELINE=$(basename "$(git rev-parse --show-toplevel 2>/dev/null)" 2>/dev/null) || {
    echo "Error: could not detect repo name. Pass PIPELINE as third argument." >&2
    exit 1
  }
fi

ORG="${4:-invoca}"

TOKEN=$(security find-generic-password -s "buildkite-api-token" -a "$(git config user.email)" -w 2>/dev/null) || {
  echo "Error: buildkite-api-token not found in keychain. See @.agents/skills/macos-keychain/SKILL.md." >&2
  exit 1
}

echo "Retrying job ${JOB_ID} in build #${BUILD} (${ORG}/${PIPELINE})..."

RESPONSE=$(curl -s -w "\n%{http_code}" \
  -H "Authorization: Bearer ${TOKEN}" \
  -X PUT \
  "https://api.buildkite.com/v2/organizations/${ORG}/pipelines/${PIPELINE}/builds/${BUILD}/jobs/${JOB_ID}/retry")

HTTP_CODE=$(echo "$RESPONSE" | tail -1)
BODY=$(echo "$RESPONSE" | head -n -1)

if [ "$HTTP_CODE" = "200" ]; then
  NEW_JOB_ID=$(echo "$BODY" | python3 -c "import sys,json; print(json.load(sys.stdin).get('id','?'))" 2>/dev/null || echo "?")
  echo "✅ Retried. New job ID: ${NEW_JOB_ID}"
  echo "   Build: https://buildkite.com/${ORG}/${PIPELINE}/builds/${BUILD}"
else
  echo "Error: retry failed (HTTP ${HTTP_CODE})" >&2
  echo "$BODY" >&2
  exit 1
fi
