{
  "source": {
    "github": {
      "owner": "Invoca",
      "repo": "agent-rules",
      "branch": "main"
    },
    "local": "../agent-rules"
  },
  "commands": {
    "target": ".agents/commands",
    "enabled": [
      "COMMIT.md",
      "CREATE-JIRA-TICKET.md",
      "DEBUG-CI.md",
      "FIX.md",
      "HYDRATE-JIRA-TICKET.md",
      "OPEN-PR.md"
    ]
  },
  "skills": {
    "target": ".agents/skills",
    "enabled": [
      "atlassian",
      "buildkite",
      "gh",
      "test-driven-development"
    ]
  },
  "protocol": {
    "shared_section": "AGENTS.md",
    "local_section": ".agents/REPO_RULES.md",
    "output": "AGENTS.md"
  }
}
